<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VidMax.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- আপনার ট্রান্সপারেন্ট স্ট্যাটাস বার এবং ডার্ক মোড সাপোর্ট -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- 🔥 Android 12+ এর ডিফল্ট স্প্ল্যাশ স্ক্রিন হাইড করার ম্যাজিক -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
</resources>
